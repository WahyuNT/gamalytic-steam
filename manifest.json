{
  "manifest_version": 3,
  "name": "Gamalytic Steam Info",
  "version": "1.1",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://gamalytic.wahyunt.me/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/app/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Gamalytic Steam Info"
  }
}